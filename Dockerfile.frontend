FROM node:22-alpine AS builder

WORKDIR /app

COPY packages/backend/ui-custom ./

# No build needed for HTML/CSS, just serve as-is

FROM nginx:alpine

COPY --from=builder /app /usr/share/nginx/html

COPY packages/backend/nginx.conf /etc/nginx/nginx.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
